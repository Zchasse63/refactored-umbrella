# ── The Portal — environment ───────────────────────────────────────────────
# Copy to .env.local and fill in once Supabase / Keepa / Anthropic are provisioned.
# Nothing below is required to run the local fixture-backed UI (npm run dev).

# Supabase (dedicated NEW project — NOT the Servous project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only; used by importers + RLS-bypassing jobs

# Keepa (competitor metrics + Product Finder discovery) — server-only
KEEPA_API_KEY=

# Anthropic Claude API (AI layer: discovery query-build, verify judge, copy cleanup, vision QA) — server-only
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
